{
  "extends": "../../tsconfig.json",

  "compilerOptions": {
    "outDir": "./dist",
    "sourceMap": true,
    "inlineSources": true,
    "ignoreDeprecations": "6.0",
    "sourceRoot": "/"
  },
  "paths": { "*": ["./src/*"] },
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts", "src/test/*"],
  "include": ["src/**/*"]
}
