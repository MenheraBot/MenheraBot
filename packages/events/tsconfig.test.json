{
  "extends": "../../tsconfig.json",

  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "moduleResolution": "node16",
    "ignoreDeprecations": "6.0",
    "sourceRoot": "/"
  },
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/test/*"
  ],
  "include": [
    "src/**/*"
  ]
}
